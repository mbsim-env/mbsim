<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<SpringDamper xmlns="http://www.mbsim-env.de/MBSim" name="EXTERN">
  <connect ref1="../Frame[SpringMount]" ref2="../Object[Ball]/Frame[C]"/>
  <forceFunction>
    <LinearSpringDamperForce>
      <stiffnessCoefficient>3</stiffnessCoefficient>
      <dampingCoefficient>0</dampingCoefficient>
    </LinearSpringDamperForce>
  </forceFunction>
  <unloadedLength>0</unloadedLength>
  <enableOpenMBV>
    <colorRepresentation>"absoluteForce"</colorRepresentation>
    <numberOfCoils>20</numberOfCoils>
    <springRadius>0.03</springRadius>
    <type>'polyline'</type>
  </enableOpenMBV>
</SpringDamper>
