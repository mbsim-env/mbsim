<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<DynamicSystemSolver xmlns="http://www.mbsim-env.de/MBSim" name="TS" xmlns:mbsimcontrol="http://www.mbsim-env.de/MBSimControl">
  <plotFeatureRecursive value="generalizedRelativePosition">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedRelativeVelocity">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedForce">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedPosition">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedVelocity">true</plotFeatureRecursive>
  <plotFeatureRecursive value="mbsimcontrol:signal">true</plotFeatureRecursive>
  <frames>
    <Embed xmlns="http://www.mbsim-env.de/MBXMLUtils" count="3" counterName="i">
      <FixedRelativeFrame xmlns="http://www.mbsim-env.de/MBSim" name="I{i}">
        <!--
        -<enableOpenMBV>
          -  <size>fSize</size>
          -  <offset>1</offset>
          -</enableOpenMBV>
        -->
        <frameOfReference ref="../Frame[I]"/>
        <relativePosition><![CDATA[
          x=linspace(-swingL/2*.6, swingL/2*.6, 3);
          ret=[x(i) swingH+.02 0]';
          ]]></relativePosition>
        <relativeOrientation>eye(3)</relativeOrientation>
      </FixedRelativeFrame>
    </Embed>
    <Embed xmlns="http://www.mbsim-env.de/MBXMLUtils" count="3" counterName="i">
      <FixedRelativeFrame xmlns="http://www.mbsim-env.de/MBSim" name="Q{i}">
        <frameOfReference ref="../Frame[I{i}]"/>
        <relativeOrientation>rotateAboutZ(pi/2)</relativeOrientation>
      </FixedRelativeFrame>
    </Embed>
  </frames>
  <contours/>
  <groups>
    <Embed xmlns="http://www.mbsim-env.de/MBXMLUtils" count="1" counterName="X" href="swing.xml"/>
    <Embed xmlns="http://www.mbsim-env.de/MBXMLUtils" count="3" counterName="i" href="metronome.xml"/>
    <Embed xmlns="http://www.mbsim-env.de/MBXMLUtils" count="3" counterName="i" href="control.xml"/>
  </groups>
  <objects/>
  <links/>
  <constraints/>
  <observers/>
  <environments>
    <MBSimEnvironment xmlns="http://www.mbsim-env.de/MBSim">
      <accelerationOfGravity>[0; -9.81; 0]</accelerationOfGravity>
    </MBSimEnvironment>
  </environments>
  <maximumNumberOfIterations>1000000</maximumNumberOfIterations>
  <projectionTolerance>eps*10</projectionTolerance>
  <generalizedRelativeVelocityTolerance>eps*10</generalizedRelativeVelocityTolerance>
  <generalizedRelativeAccelerationTolerance>eps*10</generalizedRelativeAccelerationTolerance>
  <generalizedForceTolerance>eps*10</generalizedForceTolerance>
  <generalizedImpulseTolerance>eps*10</generalizedImpulseTolerance>
  <initialProjection>false</initialProjection>
</DynamicSystemSolver>
