<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<DynamicSystemSolver xmlns="http://www.mbsim-env.de/MBSim" name="MBS" xmlns:ombv="http://www.mbsim-env.de/OpenMBV" xmlns:pv="http://www.mbsim-env.de/MBXMLUtils">
  <plotFeatureRecursive value="generalizedRelativePosition">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedRelativeVelocity">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedForce">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedPosition">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedVelocity">true</plotFeatureRecursive>
  <frames>
    <FixedRelativeFrame name="Os">
      <relativePosition>[0;0;0.04]</relativePosition>
      <relativeOrientation>[1,0,0;0,1,0;0,0,1]</relativeOrientation>
    </FixedRelativeFrame>
  </frames>
  <contours/>
  <groups/>
  <objects>
    <pv:Embed href="test.xml"/>
    <pv:Embed count="N-1+1" counterName="n_pendel" href="{filenameWithoutExt}.xml"/>
  </objects>
  <links>
    <Joint name="Gelenk1">
      <connect ref1="../Frame[I]" ref2="../Object[Stab1]/Frame[O]"/>
      <forceDirection>[1,0 ; 0,1 ; 0,0]</forceDirection>
      <forceLaw>
        <BilateralConstraint/>
      </forceLaw>
    </Joint>
    <pv:Embed count="N" counterName="n" href="Joint_n.xml"/>
  </links>
  <constraints/>
  <observers/>
  <environments>
    <MBSimEnvironment>
      <accelerationOfGravity>[0;-9.81;0]</accelerationOfGravity>
    </MBSimEnvironment>
  </environments>
</DynamicSystemSolver>
