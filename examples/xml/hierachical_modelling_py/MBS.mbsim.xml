<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<DynamicSystemSolver xmlns="http://www.mbsim-env.de/MBSim" name="{import mbxmlutils; import os.path; ret=os.path.splitext(os.path.basename(mbxmlutils.getOriginalFilename()))[0]}" xmlns:pv="http://www.mbsim-env.de/MBXMLUtils">
  <frames>
    <pv:Embed count="2" counterName="numHG">
      <FixedRelativeFrame name="Q{numHG}" xmlns="http://www.mbsim-env.de/MBSim">
        <relativePosition unit="mm">
          <xmlVector xmlns="http://www.mbsim-env.de/MBXMLUtils">
            <ele>rHG[numHG]*1000</ele>
            <ele>0</ele>
            <ele>0</ele>
          </xmlVector>
        </relativePosition>
        <relativeOrientation>
          <pv:aboutZ unit="degree">-alphaHG[numHG]*180/pi</pv:aboutZ>
        </relativeOrientation>
      </FixedRelativeFrame>
    </pv:Embed>
  </frames>
  <contours/>
  <groups>
    <pv:Embed count="2" counterName="numHG" href="Hauptgruppe.xml"/>
  </groups>
  <objects/>
  <links/>
  <constraints/>
  <observers/>
  <environments>
    <MBSimEnvironment>
      <accelerationOfGravity>
        <pv:fromFile href="{grav}"/>
      </accelerationOfGravity>
      <openMBVObject>
        <pv:Embed href="env.ombvx.py.xml"/>
      </openMBVObject>
    </MBSimEnvironment>
  </environments>
</DynamicSystemSolver>
