<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<DynamicSystemSolver xmlns="http://www.mbsim-env.de/MBSim" name="TS" xmlns:c="http://www.mbsim-env.de/MBSimControl" xmlns:h="http://www.mbsim-env.de/MBSimHydraulics" xmlns:ombv="http://www.mbsim-env.de/OpenMBV" xmlns:pv="http://www.mbsim-env.de/MBXMLUtils">
  <plotFeatureRecursive value="generalizedRelativePosition">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedRelativeVelocity">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedForce">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedPosition">true</plotFeatureRecursive>
  <plotFeatureRecursive value="generalizedVelocity">true</plotFeatureRecursive>
  <frames/>
  <contours>
    <Plane name="Ground">
      <enableOpenMBV>
        <length>[1;1]</length>
      </enableOpenMBV>
    </Plane>
  </contours>
  <groups/>
  <objects>
    <RigidBody name="Ball1">
      <generalizedInitialPosition>[0.01;0.1;0]</generalizedInitialPosition>
      <frameOfReference ref="../Frame[I]"/>
      <frameForKinematics ref="Frame[C]"/>
      <mass>1.</mass>
      <inertiaTensor>eye(3)</inertiaTensor>
      <stateDependentTranslation>
        <TranslationAlongAxesXYZ xmlns="http://www.mbsim-env.de/MBSim"/>
      </stateDependentTranslation>
      <frames/>
      <contours>
        <Sphere name="Sphere">
          <radius>0.006</radius>
          <enableOpenMBV/>
        </Sphere>
      </contours>
      <enableOpenMBVFrameC>
        <size>.001</size>
        <offset>1.</offset>
      </enableOpenMBVFrameC>
    </RigidBody>
    <RigidBody name="Ball2">
      <generalizedInitialPosition>[0.01;0;0]</generalizedInitialPosition>
      <frameOfReference ref="../Frame[I]"/>
      <frameForKinematics ref="Frame[C]"/>
      <mass>1.</mass>
      <inertiaTensor>eye(3)</inertiaTensor>
      <stateDependentTranslation>
        <TranslationAlongAxesXYZ xmlns="http://www.mbsim-env.de/MBSim"/>
      </stateDependentTranslation>
      <frames/>
      <contours>
        <Sphere name="Sphere">
          <radius>0.006</radius>
          <enableOpenMBV/>
        </Sphere>
      </contours>
      <enableOpenMBVFrameC>
        <size>.001</size>
        <offset>1.</offset>
      </enableOpenMBVFrameC>
    </RigidBody>
  </objects>
  <links>
    <MaxwellContact name="Contact" xmlns="http://www.mbsim-env.de/MBSim">
      <!--
     <contactForceLaw>
      <UnilateralConstraint xmlns="http://www.mbsim-env.de/MBSim"/>
     </contactForceLaw>
     <contactImpactLaw>
      <UnilateralNewtonImpact>
       <restitutionCoefficient>0.9</restitutionCoefficient>       
      </UnilateralNewtonImpact>      
     </contactImpactLaw>
      -->
      <connect name="Contact_Uno" ref1="../Contour[Ground]" ref2="../Object[Ball1]/Contour[Sphere]"/>
      <connect name="Contact_Due" ref1="../Contour[Ground]" ref2="../Object[Ball2]/Contour[Sphere]"/>
      <InfluenceFunction>
        <FlexibilityInfluenceFunction contourName1="../Contour[Ground]" contourName2="../Contour[Ground]">
          <Flexibility>1e-5</Flexibility>
        </FlexibilityInfluenceFunction>
      </InfluenceFunction>
    </MaxwellContact>
  </links>
  <constraints/>
  <observers>
    <MaxwellContactObserver name="ContactObserver1">
      <maxwellContact ref="../Link[Contact]"/>
      <enableOpenMBVContactPoints>
        <size>0.1</size>
      </enableOpenMBVContactPoints>
      <enableOpenMBVNormalForce>
        <colorRepresentation>"absoluteValue"</colorRepresentation>
        <scaleLength>.01</scaleLength>
      </enableOpenMBVNormalForce>
    </MaxwellContactObserver>
  </observers>
  <environments>
    <MBSimEnvironment>
      <accelerationOfGravity>[-9.81;0;0]</accelerationOfGravity>
    </MBSimEnvironment>
  </environments>
</DynamicSystemSolver>
